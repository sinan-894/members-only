<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <% if (locals.isLogin || locals.isAdmin) { %>
        <% if (locals.errors) { %>
            <% locals.errors.forEach(error => { %>
                <div><%= error.msg %></div>
             
            <% }) %>
         
        <% } %>
        <form action="/" method="post">
            <div>
                <label for="message">message:</label>
                <input type="text" name="message" id="message">
            </div>
            <input type="submit" value="post">
        </form>
    <% } else { %>
        <div>
            <a href="/login">log in </a> to post a message
        </div>
    <% } %>
    
    <div>
        <% if (locals.messages) { %>
            <% messages.forEach(message => { %>
                <div>
                    <section><%= (locals.isMember || locals.isAdmin)? message.author:"*********" %></section>
                    <section><%= (locals.isMember || locals.isAdmin)? message.date:"*********" %></section>
                    <section><%= message.text %></section>
                    <% if (locals.isAdmin) { %>
                        <a href="/delete?id=<%= message.id %>">delete</a>
                    <% } %>

                </div>
            <% }) %>
         
        <% } %>
    </div>
</body>
</html>